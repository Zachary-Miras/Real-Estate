# --- Prisma / MongoDB ---
# Local (exemple)
DATABASE_URL="mongodb://localhost:27017/RealEstate"
# Cloud (exemple)
# DATABASE_URL="mongodb+srv://USER:PASSWORD@HOST/RealEstate?retryWrites=true&w=majority"

# --- Google Maps ---
NEXT_PUBLIC_MAPS_API_KEY="CHANGE_ME"

# --- EmailJS (contact) ---
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID="CHANGE_ME"
NEXT_PUBLIC_EMAILJS_SERVICE_ID="CHANGE_ME"
NEXT_PUBLIC_EMAILJS_USER_ID="CHANGE_ME"

# --- NextAuth (Backoffice) ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING"

# Accès backoffice (emails séparés par virgule)
ADMIN_EMAILS="admin@example.com"

# Optionnel : si défini, seuls STAFF_EMAILS + ADMIN_EMAILS peuvent se connecter
STAFF_EMAILS="agent1@example.com,agent2@example.com"
